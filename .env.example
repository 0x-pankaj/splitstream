# ─────────────────────────────────────────────────────────────────────────────
# Arcane Treasury — environment template. Copy to .env and fill in.
# NEVER commit a real .env. Arc Testnet USDC has no real-world value.
# ─────────────────────────────────────────────────────────────────────────────

# Arc Testnet RPC (chain id 5042002). USDC is the native gas token.
# For the Lepton event, use the Canteen-hosted Arc node from `arc-canteen` (it
# carries a per-user swrm_… secret token — keep it in a gitignored .env only).
# Same chain id as the public RPC below, so balances/txs are identical state.
ARC_TESTNET_RPC_URL="https://rpc.testnet.arc.network"
ARC_TESTNET_WS_URL="wss://rpc.testnet.arc.network"

# Demo-piece creators (optional) — point the seeded showcase split at REAL
# recruited-creator EVM wallets so their earnings show on the live leaderboard.
# Unset → EVM placeholders. Live split is EVM-only (Base/Arbitrum/Ethereum) so
# every leg settles real on Arc with no skipped contributor.
SEED_WRITER_ADDRESS=""
SEED_EDITOR_ADDRESS=""
SEED_PHOTOGRAPHER_ADDRESS=""

# Relayer key — signs executeIntent() on ArcaneTreasuryVault. Fund it with
# Arc Testnet USDC from the Circle Faucet (USDC pays gas). Use a throwaway key.
RELAYER_PRIVATE_KEY="0x..."

# Deployed contract addresses (populated by contracts/script/DeployArcTestnet.s.sol)
VAULT_ADDRESS=""
COMPLIANCE_GUARD_ADDRESS=""
MOCK_USYC_TELLER_ADDRESS=""

# SaaS protocol fee wallet (receives convenienceFee)
PLATFORM_FEE_WALLET=""

# Circle App Kit key (free, from Circle Console) — required for Swap (USDC->EURC).
CIRCLE_KIT_KEY=""

# Hybrid router threshold: payouts strictly below this (6dp USDC) take the instant
# Gateway path; at/above it they take the native CCTP whale path. Default $5,000.
INSTANT_PATH_THRESHOLD_USDC="5000"

# Real rails (require a funded RELAYER_PRIVATE_KEY; no kit key needed for either):
#  LIVE_BRIDGE   — whale path does a REAL CCTP burn-on-Arc → mint-on-destination.
#  LIVE_GATEWAY  — instant path does a REAL Gateway unified-balance spend (<500ms).
#                  Requires a funded Gateway float on Arc (unifiedBalance.deposit).
#  LIVE_X402     — real on-chain x402 + human wallet-payment settlement on Arc.
# Leave unset (or "false") to run those rails in deterministic simulation.
LIVE_BRIDGE="false"
LIVE_GATEWAY="false"
LIVE_X402="false"

# Autonomous demo agent — powers the in-app "Agent pays REAL USDC on Arc" button.
DEMO_AGENT_PRIVATE_KEY="0x..."

# Reading-agent LLM via OpenRouter (NOT Anthropic). No key → heuristic fallback.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-v4-pro"

# Circle Developer-Controlled Wallets — assign each creator a custodial USDC
# wallet on Arc at signup (pre-created pool). All three required to enable real
# wallets; unset → creators get a labeled local-dev address (mirror mode).
#   CIRCLE_API_KEY        — from the Circle developer console.
#   CIRCLE_ENTITY_SECRET  — your registered entity secret (32-byte hex).
#   CIRCLE_WALLET_SET_ID  — the wallet set new creator wallets are created under.
CIRCLE_API_KEY=""
CIRCLE_ENTITY_SECRET=""
CIRCLE_WALLET_SET_ID=""

# Creator login email (one-time codes) via Resend. Unset → the code is logged to
# the server console so the email→OTP flow still works with zero keys in dev.
EMAIL_API_KEY=""
EMAIL_FROM="SplitStream <login@splitstream.app>"

# Hardening (optional):
#   SNAPSHOT_ENC_KEY — any string; the store snapshot (API keys, upstream API
#     credentials, creator emails) is AES-256-GCM encrypted at rest in D1/sqlite.
#     Unset → plaintext snapshot (existing snapshots stay readable either way).
#   CORS_ORIGINS — comma-separated browser origins allowed to call the API. Unset
#     → open CORS (the public storefront + embeddable widget work from anywhere).
SNAPSHOT_ENC_KEY=""
CORS_ORIGINS=""

# Cloudflare D1 — managed durable persistence. When all three are set the store
# snapshot lives in D1 (survives service/volume loss); else falls back to sqlite.
# Token scope: Account > D1 > Edit.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_API_TOKEN=""

# Cloudflare R2 — media uploads (a seller's photo/song becomes gated content).
# S3-compatible creds from R2 > Manage R2 API Tokens; R2_PUBLIC_URL is the
# bucket's public r2.dev base. Unset → uploads return 503 (text/URL content only).
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="splitstream"
R2_PUBLIC_URL=""

# Backend
DATABASE_PATH="./data/arcane.sqlite"
PORT="8787"

# Web dashboard
NEXT_PUBLIC_API_URL="http://localhost:8787"
